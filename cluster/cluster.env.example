# Bitrix cluster configuration example.
# Copy to cluster.env and adjust before running install scripts.

# Git source for remote install (cluster/run.sh pulls only files needed for each role)
BITRIX_CLUSTER_REPO=https://github.com/YOURORG/bitrix_al9.git
BITRIX_CLUSTER_REF=main
# BITRIX_CLUSTER_CACHE=/var/cache/bitrix-cluster

CLUSTER_DOMAIN=example.com

# Load balancers (keepalived VIP)
VIP=10.0.0.100
KEEPALIVED_INTERFACE=eth0
KEEPALIVED_ROUTER_ID=51
# lb1: KEEPALIVED_STATE=MASTER KEEPALIVED_PRIORITY=100
# lb2: KEEPALIVED_STATE=BACKUP KEEPALIVED_PRIORITY=90
KEEPALIVED_STATE=MASTER
KEEPALIVED_PRIORITY=100
KEEPALIVED_PEER=10.0.0.12

# Application servers (nginx upstream backends)
APP_SERVERS=10.0.0.21:8080,10.0.0.22:8080
MEMCACHED_PORT=11211
MEMCACHED_BIND=0.0.0.0

# MySQL
MYSQL_MASTER=10.0.0.31
MYSQL_SLAVE=10.0.0.32
MYSQL_ROOT_PASSWORD=ChangeMeRoot
MYSQL_VERSION=8.0
REPL_USER=repl
REPL_PASSWORD=ChangeMeRepl
MYSQL_SERVER_ID=1
MASTER_HOST=10.0.0.31
MASTER_PORT=3306

# Push server
PUSH_HOST=10.0.0.41
WS_HOST=10.0.0.41

# OpenSearch (single-node)
OPENSEARCH_HOST=10.0.0.51
OPENSEARCH_PORT=9200
OPENSEARCH_BIND_HOST=10.0.0.51
OPENSEARCH_CLUSTER_NAME=bitrix-search
OPENSEARCH_NODE_NAME=search1
OPENSEARCH_HEAP_SIZE=2g
OPENSEARCH_ADMIN_PASSWORD=ChangeMeSearch

# Transformer (only one app node — app1)
TRANSFORMER_ENABLED=1
SITE_NAME=default
RABBITMQ_USER=transformer
RABBITMQ_PASSWORD=ChangeMeRabbit
RABBITMQ_VHOST=bitrix

# ---------------------------------------------------------------------------
# Deployment order:
#   1. install-mysql-master.sh  (-c cluster.env -s -M "$MYSQL_ROOT_PASSWORD")
#   2. install-mysql-slave.sh   (-c cluster.env -s -M "$MYSQL_ROOT_PASSWORD")
#   3. install-opensearch.sh    (-c cluster.env -s)
#   4. install-push.sh          (-c cluster.env -s)
#   5. install-app.sh --with-transformer on app1; install-app.sh on app2
#   6. install-balancer.sh on lb1/lb2 (set KEEPALIVED_STATE/PRIORITY per host)
#
# Post-install (after Bitrix site install):
#   - .settings.php: DB host, memcached, push URLs, OpenSearch URL
#   - Push&Pull: SECURITY_KEY from /etc/sysconfig/push-server-multi
#   - Search module: OpenSearch https://OPENSEARCH_HOST:9200
#   - transformer + transformercontroller: /etc/bitrix-transformer.env
#   - Drive: view documents via Bitrix24
